{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    "helpers:pinGitHubActionDigests"
  ],
  "labels": ["dependencies"],
  "pinDigests": true,
  "packageRules": [
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "Workflow input fields (e.g. golangci-lint-action `version:`, setup-go `go-version:`) cannot carry a digest comment, so pinDigests fails the branch.",
      "matchDepTypes": ["uses-with"],
      "pinDigests": false
    },
    {
      "matchManagers": ["gomod"],
      "groupName": "Go dependencies"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "matchManagers": ["dockerfile"],
      "groupName": "Docker base images"
    }
  ]
}
